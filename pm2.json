{
  "apps": [
    {
      "name": "automation-stack",
      "script": "php",
      "args": "artisan automation:stack --no-workers",
      "cwd": "/var/www/auction.ellectmobility.com",
      "autorestart": true,
      "watch": false,
      "restart_delay": 10000,
      "max_memory_restart": "1G"
    },
    {
      "name": "queue-default",
      "script": "php",
      "args": "artisan queue:work --sleep=3 --tries=3 --timeout=300",
      "cwd": "/var/www/auction.ellectmobility.com",
      "autorestart": true,
      "watch": false,
      "restart_delay": 5000
    },
    {
      "name": "queue-bids",
      "script": "php",
      "args": "artisan queue:work --queue=bids --sleep=1 --tries=3 --timeout=300",
      "cwd": "/var/www/auction.ellectmobility.com",
      "autorestart": true,
      "watch": false,
      "restart_delay": 5000
    }
  ]
}